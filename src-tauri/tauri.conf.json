{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "通用阅读器",
  "version": "1.0.8",
  "identifier": "com.reader.md",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "通用阅读器",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "backgroundColor": "#f5f5f7"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "appimage",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "fileAssociations": [
      {
        "name": "Markdown",
        "ext": ["md", "mdx"],
        "description": "Markdown File",
        "role": "Editor"
      },
      {
        "name": "Text",
        "ext": ["txt", "log", "csv", "json", "xml", "yaml", "yml", "toml", "ini", "cfg", "conf", "env"],
        "description": "Text File",
        "role": "Editor"
      },
      {
        "name": "Code",
        "ext": ["js", "ts", "jsx", "tsx", "mjs", "cjs", "vue", "svelte", "astro", "py", "rb", "php", "sh", "bash", "zsh", "css", "scss", "less", "sass", "styl", "java", "c", "cpp", "h", "hpp", "go", "rs", "swift", "kt", "dart", "lua", "r", "pl", "sql", "tex", "rst", "bat", "cmd", "ps1", "gradle", "dockerfile", "gitignore", "editorconfig", "htaccess", "makefile", "cmake"],
        "description": "Code File",
        "role": "Editor"
      },
      {
        "name": "HTML",
        "ext": ["html", "htm"],
        "description": "HTML File",
        "role": "Viewer"
      },
      {
        "name": "PDF",
        "ext": ["pdf"],
        "description": "PDF Document",
        "role": "Viewer"
      },
      {
        "name": "Word",
        "ext": ["doc", "docx", "wps", "wpt"],
        "description": "Word Document",
        "role": "Editor"
      },
      {
        "name": "Excel",
        "ext": ["xls", "xlsx", "et", "ett"],
        "description": "Excel Spreadsheet",
        "role": "Editor"
      },
      {
        "name": "PowerPoint",
        "ext": ["ppt", "pptx", "dps", "dpt"],
        "description": "PowerPoint Presentation",
        "role": "Viewer"
      }
    ]
  }
}
